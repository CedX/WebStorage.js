{
	"include": ["**/*.ts"],
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"erasableSyntaxOnly": true,
		"incremental": true,
		"module": "NodeNext",
		"noEmit": false,
		"noImplicitOverride": true,
		"outDir": "../Distributable",
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"target": "ESNext",
		"tsBuildInfoFile": "../Temp/TSBuildInfoFile.json",
		"verbatimModuleSyntax": true
	}
}
